# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=klyovo_bot

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_at_least_32_chars

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://klyovo:klyovo_dev@localhost:5432/klyovo
POSTGRES_PASSWORD=klyovo_dev

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_dev@localhost:6379
REDIS_PASSWORD=redis_dev

# ─── AI / LLM ────────────────────────────────────────────────────────────────
YANDEX_GPT_API_KEY=your_yandexgpt_api_key
YANDEX_GPT_FOLDER_ID=your_yandex_folder_id

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PLUS
}

enum Category {
  FOOD_CAFE
  GROCERIES
  MARKETPLACE
  TRANSPORT
  SUBSCRIPTIONS
  ENTERTAINMENT
  HEALTH
  CLOTHING
  EDUCATION
  OTHER
}

enum Source {
  CSV_SBER
  CSV_TBANK
  MANUAL
}

enum SubscriptionStatus {
  active
  cancelled
  ignored
}

enum KlyovoSubPlan {
  plus_monthly
  plus_yearly
}

enum KlyovoSubStatus {
  active
  cancelled
  expired
}

model User {
  id               String    @id @default(uuid())
  telegramId       BigInt    @unique
  telegramUsername String?
  displayName      String
  plan             Plan      @default(FREE)
  planExpiresAt    DateTime?
  referralCode     String    @unique @default(cuid())
  referredBy       String?
  consentGivenAt   DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  transactions      Transaction[]
  roastSessions     RoastSession[]
  subscriptions     DetectedSubscription[]
  klyovoSubs        KlyovoSubscription[]
  bnplObligations   BnplObligation[]
  financialGoals    FinancialGoal[]
  userStreak        UserStreak?
  achievements      UserAchievement[]
}

model Transaction {
  id                 String   @id @default(uuid())
  userId             String
  amountKopecks      Int
  merchantName       String
  merchantNormalized String
  category           Category
  transactionDate    DateTime
  source             Source
  rawDescription     String?
  isBnpl             Boolean  @default(false)
  bnplService        String?
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, transactionDate, amountKopecks, merchantNormalized])
  @@index([userId, transactionDate])
}

model RoastSession {
  id              String    @id @default(uuid())
  userId          String
  roastText       String
  spendingSummary Json
  mode            String
  sharedAt        DateTime?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model DetectedSubscription {
  id              String             @id @default(uuid())
  userId          String
  merchantName    String
  estimatedAmount Int
  frequencyDays   Int
  lastChargeDate  DateTime
  occurrences     Int                @default(1)
  status          SubscriptionStatus @default(active)
  createdAt       DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, merchantName])
  @@index([userId, status])
}

model KlyovoSubscription {
  id               String          @id @default(uuid())
  userId           String
  plan             KlyovoSubPlan
  status           KlyovoSubStatus @default(active)
  yookassaPaymentId String         @unique
  startedAt        DateTime
  expiresAt        DateTime
  createdAt        DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

enum BnplStatus {
  active
  completed
  overdue
  dismissed
}

enum GoalCategory {
  SAVINGS
  EMERGENCY_FUND
  VACATION
  GADGET
  EDUCATION
  HOUSING
  OTHER
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

model BnplObligation {
  id                String     @id @default(uuid())
  userId            String
  bnplService       String
  merchantName      String
  merchantDisplay   String
  installmentAmount Int
  totalInstallments Int
  paidInstallments  Int
  firstPaymentDate  DateTime
  lastPaymentDate   DateTime
  nextPaymentDate   DateTime?
  frequencyDays     Int
  status            BnplStatus @default(active)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bnplService, merchantName, firstPaymentDate])
  @@index([userId, status])
}

model FinancialGoal {
  id                   String        @id @default(uuid())
  userId               String
  name                 String
  category             GoalCategory
  targetAmountKopecks  Int
  currentAmountKopecks Int           @default(0)
  deadline             DateTime?
  status               GoalStatus    @default(ACTIVE)
  aiAdvice             String?
  aiAdviceGeneratedAt  DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

enum AchievementType {
  FIRST_IMPORT
  WEEK_STREAK
  MONTH_STREAK
  FIRST_ROAST
  GOAL_COMPLETE
  SUBSCRIPTION_KILLER
  BUDGET_MASTER
  SOCIAL_SHARER
  REFERRAL_ACE
}

model UserStreak {
  id                    String    @id @default(uuid())
  userId                String    @unique
  importStreak          Int       @default(0)
  importStreakLongest   Int       @default(0)
  importLastDate        DateTime? @db.Date
  spendingStreak        Int       @default(0)
  spendingStreakLongest Int       @default(0)
  spendingLastWeek      String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserAchievement {
  id          String          @id @default(uuid())
  userId      String
  achievement AchievementType
  unlockedAt  DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievement])
  @@index([userId])
}
